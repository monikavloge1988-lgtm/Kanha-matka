rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users
    match /users/{userId} {
      // User can read their own profile. Admin can read all.
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // No listing users randomly unless admin
      allow list: if isAdmin();
      
      // Zero client writes. The API does all the work.
      allow write: if false;
    }

    // Game State
    match /game/state {
      // Anyone signed in can read the game state
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Bets
    match /bets/{betId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // History
    match /history/{roundId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
